APP_NAME=AI Document Knowledge Base
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=sqlite:///./knowledge_base.db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_base
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_USE_HTTP=false
CHROMA_PERSIST_DIRECTORY=./.chroma
CHROMA_COLLECTION_NAME=documents
CHROMA_HNSW_SPACE=cosine
CHROMA_HNSW_M=48
CHROMA_HNSW_EF_CONSTRUCTION=200
CHROMA_QUERY_EF=80
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_DEPARTMENT=general
# Set true to load demo docs on API startup (same as: python seed_documents.py)
SEED_DEMO_DOCUMENTS_ON_STARTUP=false
UPLOAD_STORAGE_DIRECTORY=./uploads
